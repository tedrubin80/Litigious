# Frontend environment (copy to frontend/.env.local for local dev)

# Branding
VITE_APP_NAME=Litigious
VITE_APP_TAGLINE=Legal Practice Management
VITE_MARKETING_URL=https://litigiousweb.vercel.app
VITE_DOCS_URL=https://github.com/tedrubin80/Litigious/blob/main/docs/INSTALL.md

# Demo UI (banner, tour, credential hints) — default on for clone-and-try
VITE_DEMO_MODE=true

# API base URL — use /api when served behind nginx proxy
VITE_API_URL=/api

# Legacy CRA shim (vite.config maps these too)
REACT_APP_API_URL=/api
REACT_APP_API_TIMEOUT=10000

# Socket / realtime (optional)
VITE_WS_URL=
