# Frontend environment variables (copy to frontend/.env)

# Vite-native names (preferred)
VITE_API_URL=/api
VITE_API_PROXY_TARGET=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001
VITE_DEMO_MODE=false
VITE_PACKAGE_TYPE=development
VITE_APP_NAME=LegalEstate
VITE_APP_VERSION=1.0.0

# CRA names still supported via vite.config.mjs shims
REACT_APP_API_URL=/api
REACT_APP_SOCKET_URL=http://localhost:3001
