# Backend environment variables (copy to backend/.env)

NODE_ENV=development
PORT=3001

# Required secrets — generate with: openssl rand -hex 32
JWT_SECRET=
SESSION_SECRET=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/litigious

# Frontend / CORS
FRONTEND_URL=http://localhost:3000
HTTP_FALLBACK_URL=http://localhost:3000
FORCE_HTTPS=false

# Registration — disabled by default; set true only for controlled onboarding
ALLOW_PUBLIC_REGISTRATION=false

# Admin bootstrap scripts (never commit real values)
ADMIN_EMAIL=admin@litigious.online
ADMIN_PASSWORD=

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Integrations (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=

# File storage paths
RECORDINGS_PATH=/var/www/html/recordings
STREAMS_PATH=/var/www/html/streams
FRONTEND_BUILD_PATH=/var/www/html/frontend/build

# Phase 1 security
PII_ENCRYPTION_KEY=
ALLOWED_ORIGINS=https://litigious.online,https://www.litigious.online
CLAMAV_ENABLED=false
CLAMSCAN_PATH=clamscan
CLAMAV_SCAN_TIMEOUT_MS=30000
EXPOSE_AUTH_TOKEN_IN_RESPONSE=false

# Phase 5 DevOps
METRICS_ENABLED=false
METRICS_TOKEN=
BACKUP_PASSPHRASE=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
