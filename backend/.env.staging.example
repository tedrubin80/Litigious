# Staging environment — mirrors production security with separate secrets

NODE_ENV=staging
PORT=3001

JWT_SECRET=
SESSION_SECRET=
PII_ENCRYPTION_KEY=
BACKUP_PASSPHRASE=

DATABASE_URL=postgresql://staging_user:password@localhost:5432/legalestate_staging

FRONTEND_URL=https://staging.legalestate.tech
ALLOWED_ORIGINS=https://staging.legalestate.tech
FORCE_HTTPS=true
ALLOW_PUBLIC_REGISTRATION=false
EXPOSE_AUTH_TOKEN_IN_RESPONSE=false

CLAMAV_ENABLED=true
METRICS_ENABLED=true
METRICS_TOKEN=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@staging.legalestate.tech
