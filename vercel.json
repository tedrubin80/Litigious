{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "marketing": {
      "root": "website",
      "installCommand": "echo \"static marketing site\"",
      "buildCommand": "echo \"static marketing site\"",
      "outputDirectory": "."
    },
    "app": {
      "root": "frontend",
      "framework": "vite",
      "installCommand": "npm install",
      "buildCommand": "npm run build",
      "outputDirectory": "build"
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "app.litigious.online" }],
      "destination": { "service": "app" }
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "litigious.online" }],
      "destination": { "service": "app" }
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.litigious.online" }],
      "destination": { "service": "app" }
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "litigiousweb.vercel.app" }],
      "destination": { "service": "marketing" }
    },
    {
      "source": "/:path*",
      "destination": { "service": "app" }
    }
  ]
}
